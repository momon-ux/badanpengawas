function login(){
const user="disiplin";
const pass="1234";

let u=document.getElementById("username").value;
let p=document.getElementById("password").value;

if(u===user && p===pass){
window.location.href="home.html";
}else{
document.getElementById("error").innerText="Login Salah!";
}
}

