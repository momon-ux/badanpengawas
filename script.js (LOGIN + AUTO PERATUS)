];

// Load data
function getData(){
let data = localStorage.getItem("pengawas");
return data ? JSON.parse(data) : defaultData;
}

// Save data
function saveData(data){
localStorage.setItem("pengawas", JSON.stringify(data));
}

// =======================
// TAMBAH MURID
// =======================
function tambahPengawas(){
let nama=document.getElementById("nama").value;
let kelas=document.getElementById("kelas").value;
let jantina=document.getElementById("jantina").value;

if(nama==="") return alert("Isi nama dahulu");

let data=getData();
data.push({name:nama,kelas:kelas,jantina:jantina});
saveData(data);
location.reload();
}

// =======================
// PAPAR SENARAI
// =======================
if(document.getElementById("tableBody")){
let data=getData();
let table=document.getElementById("tableBody");
table.innerHTML="";

data.forEach((d,index)=>{
table.innerHTML+=`
<tr>
<td>${d.name}</td>
<td>${d.kelas}</td>
<td>${d.jantina}</td>
<td><button onclick="padam(${index})">Padam</button></td>
</tr>`;
});
}

// =======================
// PADAM
// =======================
function padam(index){
let data=getData();
data.splice(index,1);
saveData(data);
location.reload();
}

// =======================
// STATISTIK
// =======================
if(document.getElementById("total")){
let data=getData();
let lelaki=data.filter(d=>d.jantina==="Lelaki").length;
let perempuan=data.filter(d=>d.jantina==="Perempuan").length;
let total=data.length;

document.getElementById("total").innerText=total;
document.getElementById("lelaki").innerText=lelaki;
document.getElementById("perempuan").innerText=perempuan;
document.getElementById("percentL").innerText=((lelaki/total)*100).toFixed(1)+"%";
document.getElementById("percentP").innerText=((perempuan/total)*100).toFixed(1)+"%";

new Chart(document.getElementById("genderChart"),{
type:"pie",
data:{
labels:["Lelaki","Perempuan"],
datasets:[{
data:[lelaki,perempuan],
backgroundColor:["#3498db","#e91e63"]
}]
}
});
}

// =======================
// EXPORT CSV
// =======================
function exportCSV(){
let data=getData();
let csv="Nama,Kelas,Jantina\n";

data.forEach(d=>{
csv+=`${d.name},${d.kelas},${d.jantina}\n`;
});

let blob=new Blob([csv],{type:"text/csv"});
let url=URL.createObjectURL(blob);

let a=document.createElement("a");
a.href=url;
a.download="senarai_pengawas.csv";
a.click();
}
